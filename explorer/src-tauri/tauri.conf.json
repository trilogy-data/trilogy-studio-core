{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trilogy Explorer",
  "version": "0.0.0",
  "identifier": "dev.trilogydata.explorer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5180",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Trilogy Explorer",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
