{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@lib/*": ["../lib/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "../lib/**/*.ts", "../lib/**/*.vue"]
}
